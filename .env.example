# La maquinarIA — Environment Variables (Level 1: Infrastructure Secrets)
# Copy this file to .env and fill in values. Never commit .env to version control.

# Database
DATABASE_URL=

# Authentication
JWT_SECRET=
JWT_EXPIRATION=3600

# Encryption (for Level 3 credential storage)
ENCRYPTION_KEY=

# Application
APP_ENV=development
APP_PORT=3000
APP_LOG_LEVEL=info
